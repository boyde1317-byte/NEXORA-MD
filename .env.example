# ─── Nexora MD — Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Railway / Render / Pterodactyl inject these as environment variables instead.

# ── AI Features (optional) ────────────────────────────────────────────────────
# Required for AI-generated menu/greeting images.
GEMINI_API_KEY=

# Set to "true" to enable automatic AI asset generation on startup.
# Disabled by default to avoid unintended API usage.
GENERATE_ASSETS=false

# ── Deployment (auto-injected on Railway / Render / Replit) ───────────────────
# The port the web server listens on. Defaults to 3000 if not set.
PORT=3000
